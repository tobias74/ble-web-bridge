{
  "name": "ble-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source BLE telemetry relay for games and realtime apps.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/server",
    "apps/web",
    "apps/demo-game"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace @ble-bridge/server",
    "dev:web": "npm run dev --workspace @ble-bridge/web",
    "dev:demo": "npm run dev --workspace @ble-bridge/demo-game",
    "start": "npm run start --workspace @ble-bridge/server",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.11"
  }
}
